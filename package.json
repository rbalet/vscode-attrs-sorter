{
  "name": "vscode-sorting-attrs",
  "displayName": "Sort HTML attributes",
  "description": "Sorting the tag attributes in the specified order",
  "version": "1.0.6",
  "author": "Raphaël Balet",
  "publisher": "rbalet",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icon.png",
  "homepage": "https://github.com/rbalet/vscode-attrs-sorter/blob/master/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/rbalet/vscode-attrs-sorter"
  },
  "keywords": [
    "html",
    "attributes",
    "sort"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:attrsSorter.execute",
    "onLanguage:html"
  ],
  "main": "./extension",
  "contributes": {
    "commands": [
      {
        "command": "attrsSorter.execute",
        "title": "Sorting HTML tag attributes (attrs-sorter)"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "AttrsSorter configuration",
      "properties": {
        "attrsSorter.order": {
          "type": "array",
          "default": [],
          "description": "An array of attributes in the correct order"
        }
      }
    }
  },
  "scripts": {
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "dev:host": "sh -c 'code --extensionDevelopmentPath=. || \"/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code\" --extensionDevelopmentPath=.'",
    "test:unit": "node --test test/*.js",
    "test:smoke": "node ./test/smoke/run.js",
    "test": "npm run lint && npm run test:unit",
    "test:ci": "npm run lint && npm run test:unit && npm run test:smoke"
  },
  "dependencies": {
    "posthtml": "^0.11.6"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@types/node": "^22.15.30",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^5.8.3"
  }
}
